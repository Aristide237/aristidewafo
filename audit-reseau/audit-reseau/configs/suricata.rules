# 1. Détection d'administration en clair (Telnet)
alert tcp any any -> $HOME_NET 23 (msg:"ALERTE - Tentative de connexion Telnet detecter"; sid:1000001; rev:1;)

# 2. Détection de scan de ports (SYN Scan)
alert tcp any any -> $HOME_NET any (msg:"ALERTE - Detection de scan de ports (SYN Scan)"; flags:S,!A; detection_filter:track by_src, count 50, seconds 10; sid:1000002; rev:1;)

# 3. Détection de Rogue DHCP
alert udp !10.0.30.10 67 -> any 68 (msg:"ALERTE - Serveur DHCP illegitime (Rogue DHCP) detecte"; sid:1000003; rev:1;)

# 4. Détection de trafic Web suspect (admin get)
alert http $EXTERNAL_NET any -> 10.0.20.10 80 (msg:"ALERTE - Trafic HTTP suspect : Tentative d'acces admin SRV-WEB"; http_method; content:"GET"; http_uri; content:"/admin"; sid:1000004; rev:1;)

# 5. Détection de l'activité liée à l'interception de ping
alert icmp any any -> $HOME_NET any (msg:"ALERTE - Activite ICMP suspecte"; detection_filter:track by_src, count 100, seconds 5; sid:1000005; rev:1;)
